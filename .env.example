# Supabase — get these from your Supabase project dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# YouTube Data API v3 — get from Google Cloud Console
# https://console.cloud.google.com/ → Enable "YouTube Data API v3" → Create credentials
YOUTUBE_API_KEY=your-youtube-api-key

# If left blank, the app uses rich mock data so you can develop without API keys
